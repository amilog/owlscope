---
import '../styles/globals.css';
import '../styles/owlscope-theme.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Universal debug & monitoring tool for JavaScript and Flutter',
  ogImage = '/og-image.svg',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/owlscope-favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://owlscope.dev').toString()} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@owlscope" />
    <link rel="preconnect" href="https://api.github.com" />
    <script is:inline>
      const stored = localStorage.getItem('starlight-theme');
      document.documentElement.dataset.theme = stored || 'dark';
    </script>
  </head>
  <body>
    <header class="owl-landing-header">
      <a href="/" class="logo">
        <img src="/owlscope-logo-animated.svg" alt="" width="28" height="28" />
        <span>OwlScope</span>
      </a>
      <nav>
        <a href="/getting-started/installation/">Docs</a>
        <a href="/guides/react/">Guides</a>
        <a href="/blog">Blog</a>
        <a href="https://github.com/YOUR_USERNAME/owlscope" rel="noopener noreferrer">GitHub</a>
        <a href="/download" class="cta">Download</a>
      </nav>
    </header>

    <main class="owl-landing-main">
      <slot />
    </main>

    <Footer />

    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family: var(--sl-font);
        background: var(--sl-color-bg);
        color: var(--sl-color-white);
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .owl-landing-header {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 32px;
        background: rgba(13, 13, 13, 0.7);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--sl-color-gray-5);
      }
      .owl-landing-header .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        font-size: 15px;
        color: var(--sl-color-white);
        letter-spacing: -0.02em;
      }
      .owl-landing-header nav {
        display: flex;
        align-items: center;
        gap: 24px;
      }
      .owl-landing-header nav a {
        color: var(--sl-color-gray-2);
        font-size: 14px;
        font-weight: 500;
        transition: color 0.15s;
      }
      .owl-landing-header nav a:hover { color: var(--sl-color-white); }
      .owl-landing-header nav .cta {
        background: var(--sl-color-accent);
        color: var(--sl-color-bg) !important;
        padding: 6px 14px;
        border-radius: 6px;
      }
      .owl-landing-header nav .cta:hover { background: var(--sl-color-accent-high); }
      .owl-landing-main { min-height: 60vh; }

      @media (max-width: 700px) {
        .owl-landing-header { padding: 12px 16px; }
        .owl-landing-header nav { gap: 14px; }
        .owl-landing-header nav a:not(.cta) { display: none; }
      }
    </style>
  </body>
</html>
