{
  "name": "owlscope",
  "version": "0.1.0",
  "private": true,
  "description": "OwlScope JavaScript/TypeScript client SDK",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auto": {
      "types": "./src/auto.ts",
      "import": "./src/auto.ts",
      "default": "./src/auto.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@owlscope/protocol": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
